# Copy this file to .env and fill in your real values.
# Never commit the real .env file to GitHub — add it to .gitignore.

# --- Email (used to send the alert, and optionally to send a "text" via
#      your carrier's email-to-SMS gateway) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=youraddress@gmail.com
# For Gmail you MUST use an App Password, not your normal password:
# https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password_here

# Where alert emails should be sent (can be the same as SMTP_USERNAME)
ALERT_EMAIL_TO=youraddress@gmail.com

# --- Optional: "free text message" via carrier email-to-SMS gateway ---
# Leave blank to disable. Format: your10digitnumber@carriergateway.com
# Verizon:    number@vtext.com
# AT&T:       number@txt.att.net
# T-Mobile:   number@tmomail.net
# Google Fi:  number@msg.fi.google.com
ALERT_SMS_GATEWAY=

# --- Optional: Best Buy official API key (free, recommended) ---
# Get one at https://developer.bestbuy.com/
BESTBUY_API_KEY=
